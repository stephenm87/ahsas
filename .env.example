# ============================================================
#  AHSAS — Environment Variables
#  Copy this to .env and fill in your real values.
#  NEVER commit .env — it is in .gitignore
# ============================================================

# --- Supabase (shared project) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ⚠️  SERVICE ROLE KEY — NOT needed with RLS enabled.
# After running supabase/migrations/001_enable_rls_user_data.sql,
# the anon key is sufficient for all AHSAS operations.
# Do NOT add this back unless you have a specific admin use case.
# SUPABASE_SERVICE_ROLE_KEY=not_needed

# --- AI APIs ---
GEMINI_API_KEY=your_gemini_key_here
